                <Grid Grid.Column="0">
                    <Button x:Name="SourceSelectorButton"
                            Height="29"
                            Click="SourceSelectorButton_Click"
                            Style="{StaticResource SelectorButtonStyle}">
                        <Grid Margin="13,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="SourceLanguageText"
                                       VerticalAlignment="Center"
                                       FontFamily="Inter"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#C2C2C2"
                                       TextTrimming="CharacterEllipsis" />

                            <Path Grid.Column="1"
                                  Width="7"
                                  Height="4"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 7 0 L 3.5 4 Z"
                                  Fill="#686868"
                                  Stretch="Fill" />
                        </Grid>
                    </Button>

                    <Popup x:Name="SourcePopup"
                           AllowsTransparency="True"
                           HorizontalOffset="0"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=SourceSelectorButton}"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Width="180"
                                Margin="0,8,0,0"
                                Padding="6"
                                Background="#262626"
                                BorderBrush="#3B3B3B"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel x:Name="SourceMenuPanel" />
                        </Border>
                    </Popup>
                </Grid>

                <Grid Grid.Column="1"
                      Width="18"
                      Height="18"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Button x:Name="SwapLanguagesButton"
                            Width="18"
                            Height="18"
                            Click="SwapLanguagesButton_Click"
                            Style="{StaticResource IconButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource ToolbarToolTipStyle}"
                                     Content="Обратный перевод" />
                        </Button.ToolTip>
                        <ContentControl ContentTemplate="{StaticResource SwapIconTemplate}" />
                    </Button>

                    <Viewbox x:Name="BusySwapView"
                             Width="18"
                             Height="18"
                             Visibility="Collapsed"
                             ToolTipService.InitialShowDelay="250"
                             RenderTransformOrigin="0.5,0.5">
                        <Viewbox.ToolTip>
                            <ToolTip Style="{StaticResource ToolbarToolTipStyle}"
                                     Content="Перевод выполняется" />
                        </Viewbox.ToolTip>
                        <lottie:LottieAnimationView x:Name="BusySwapAnimationView"
                                                    Width="18"
                                                    Height="18"
                                                    AutoPlay="False"
                                                    RepeatCount="-1"
                                                    ResourcePath="pack://application:,,,/Assets/icons8-sync-18x18.json" />
                    </Viewbox>
                </Grid>

                <Grid Grid.Column="2">
                    <Button x:Name="TargetSelectorButton"
                            Height="29"
                            Click="TargetSelectorButton_Click"
                            Style="{StaticResource SelectorButtonStyle}">
                        <Grid Margin="13,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="TargetLanguageText"
                                       VerticalAlignment="Center"
                                       FontFamily="Inter"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#C2C2C2"
                                       TextTrimming="CharacterEllipsis" />

                            <Path Grid.Column="1"
                                  Width="7"
                                  Height="4"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 7 0 L 3.5 4 Z"
                                  Fill="#686868"
                                  Stretch="Fill" />
                        </Grid>
                    </Button>

                    <Popup x:Name="TargetPopup"
                           AllowsTransparency="True"
                           HorizontalOffset="0"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=TargetSelectorButton}"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Width="180"
                                Margin="0,8,0,0"
                                Padding="6"
                                Background="#262626"
                                BorderBrush="#3B3B3B"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel x:Name="TargetMenuPanel" />
                        </Border>
                    </Popup>
                </Grid>
            </Grid>


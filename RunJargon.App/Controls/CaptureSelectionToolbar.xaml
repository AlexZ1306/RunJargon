<UserControl x:Class="RunJargon.App.Controls.CaptureSelectionToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lottie="clr-namespace:LottieSharp.WPF;assembly=LottieSharp"
             Width="643"
             Height="46"
             Focusable="False"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <DataTemplate x:Key="SelectAreaIconTemplate">
            <Viewbox Width="17" Height="17">
                <Canvas Width="16.5" Height="16.5">
                    <Path Data="M14.25 0.25H10.25V1.25H14.25C14.802 1.25 15.25 1.698 15.25 2.25V6.25H16.25V2.25C16.25 1.1455 15.3545 0.25 14.25 0.25ZM15.25 14.25C15.25 14.802 14.802 15.25 14.25 15.25H10.25V16.25H14.25C15.3545 16.25 16.25 15.3545 16.25 14.25V10.25H15.25V14.25ZM1.25 14.25V10.25H0.25V14.25C0.25 15.3545 1.1455 16.25 2.25 16.25H6.25V15.25H2.25C1.698 15.25 1.25 14.802 1.25 14.25ZM0.25 2.25V6.25H1.25V2.25C1.25 1.698 1.698 1.25 2.25 1.25H6.25V0.25H2.25C1.1455 0.25 0.25 1.1455 0.25 2.25Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="0.5"
                          Stretch="Fill" />
                </Canvas>
            </Viewbox>
        </DataTemplate>

        <Style x:Key="SelectorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#212121" />
            <Setter Property="BorderBrush" Value="#3B3B3B" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#262626" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#4A4A4A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D1D1D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Foreground" Value="#C7C7C7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Opacity="{TemplateBinding Opacity}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconButtonBorder" Property="Background" Value="#303030" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconButtonBorder" Property="Background" Value="#252525" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentIconButtonStyle"
               BasedOn="{StaticResource BaseIconButtonStyle}"
               TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#63AADE" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="#3D7CA9" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectAreaIconButtonStyle"
               BasedOn="{StaticResource BaseIconButtonStyle}"
               TargetType="Button">
            <Style.Triggers>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseIconButtonStyle"
               BasedOn="{StaticResource BaseIconButtonStyle}"
               TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#EB5050" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="#A12A2A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#3E3E3E" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="FontFamily" Value="Inter" />
            <Setter Property="FontSize" Value="11.65" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="HorizontalOffset" Value="0" />
            <Setter Property="VerticalOffset" Value="18" />
            <Setter Property="Placement" Value="Bottom" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5.625">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarMenuItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D7D7D7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MenuItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#303030" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#252525" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Width="643"
            Height="46"
            Background="#2C2C2C"
            BorderBrush="#444444"
            BorderThickness="0,0,0,1.962"
            CornerRadius="0,0,19.621,19.621">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="459" />
                <ColumnDefinition Width="2" />
                <ColumnDefinition Width="182" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Width="416"
                  Height="29"
                  Margin="21.5,8,21.5,0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Button x:Name="SourceSelectorButton"
                            Height="29"
                            Click="SourceSelectorButton_Click"
                            Style="{StaticResource SelectorButtonStyle}">
                        <Grid Margin="13,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="SourceLanguageText"
                                       VerticalAlignment="Center"
                                       FontFamily="Inter"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#C2C2C2"
                                       TextTrimming="CharacterEllipsis" />

                            <Path Grid.Column="1"
                                  Width="7"
                                  Height="4"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 7 0 L 3.5 4 Z"
                                  Fill="#686868"
                                  Stretch="Fill" />
                        </Grid>
                    </Button>

                    <Popup x:Name="SourcePopup"
                           AllowsTransparency="True"
                           HorizontalOffset="0"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=SourceSelectorButton}"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Width="180"
                                Margin="0,8,0,0"
                                Padding="6"
                                Background="#262626"
                                BorderBrush="#3B3B3B"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel x:Name="SourceMenuPanel" />
                        </Border>
                    </Popup>
                </Grid>

                <Grid Grid.Column="1"
                      Width="18"
                      Height="18"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Button x:Name="SwapLanguagesButton"
                            Width="18"
                            Height="18"
                            Click="SwapLanguagesButton_Click"
                            MouseEnter="SwapLanguagesButton_MouseEnter"
                            MouseLeave="SwapLanguagesButton_MouseLeave"
                            PreviewMouseLeftButtonDown="SwapLanguagesButton_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="SwapLanguagesButton_PreviewMouseLeftButtonUp"
                            Style="{StaticResource BaseIconButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource ToolbarToolTipStyle}"
                                     Content="Обратный перевод" />
                        </Button.ToolTip>
                        <Grid Width="18"
                              Height="18"
                              IsHitTestVisible="False">
                            <lottie:LottieAnimationView x:Name="IdleSwapAnimationView"
                                                        Width="18"
                                                        Height="18"
                                                        AutoPlay="False"
                                                        IsHitTestVisible="False"
                                                        ResourcePath="pack://application:,,,/Assets/icons8-sync-18x18.idle.json" />
                            <lottie:LottieAnimationView x:Name="HoverSwapAnimationView"
                                                        Width="18"
                                                        Height="18"
                                                        AutoPlay="False"
                                                        Visibility="Collapsed"
                                                        IsHitTestVisible="False"
                                                        ResourcePath="pack://application:,,,/Assets/icons8-sync-18x18.hover.json" />
                            <lottie:LottieAnimationView x:Name="PressedSwapAnimationView"
                                                        Width="18"
                                                        Height="18"
                                                        AutoPlay="False"
                                                        Visibility="Collapsed"
                                                        IsHitTestVisible="False"
                                                        ResourcePath="pack://application:,,,/Assets/icons8-sync-18x18.pressed.json" />
                            <lottie:LottieAnimationView x:Name="BusySwapAnimationView"
                                                        Width="18"
                                                        Height="18"
                                                        AutoPlay="False"
                                                        RepeatCount="-1"
                                                        Visibility="Collapsed"
                                                        IsHitTestVisible="False"
                                                        ResourcePath="pack://application:,,,/Assets/icons8-sync-18x18.hover.json" />
                        </Grid>
                    </Button>
                </Grid>

                <Grid Grid.Column="2">
                    <Button x:Name="TargetSelectorButton"
                            Height="29"
                            Click="TargetSelectorButton_Click"
                            Style="{StaticResource SelectorButtonStyle}">
                        <Grid Margin="13,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="TargetLanguageText"
                                       VerticalAlignment="Center"
                                       FontFamily="Inter"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#C2C2C2"
                                       TextTrimming="CharacterEllipsis" />

                            <Path Grid.Column="1"
                                  Width="7"
                                  Height="4"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 7 0 L 3.5 4 Z"
                                  Fill="#686868"
                                  Stretch="Fill" />
                        </Grid>
                    </Button>

                    <Popup x:Name="TargetPopup"
                           AllowsTransparency="True"
                           HorizontalOffset="0"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=TargetSelectorButton}"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Width="180"
                                Margin="0,8,0,0"
                                Padding="6"
                                Background="#262626"
                                BorderBrush="#3B3B3B"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel x:Name="TargetMenuPanel" />
                        </Border>
                    </Popup>
                </Grid>
            </Grid>

            <Canvas Grid.Column="1"
                    Width="2"
                    Height="44"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    SnapsToDevicePixels="True">
                <Line X1="1"
                      Y1="0"
                      X2="1"
                      Y2="44"
                      Stroke="#444444"
                      StrokeThickness="2" />
            </Canvas>

            <Grid Grid.Column="2"
                  Width="182"
                  Height="44"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top">
                <Grid Width="160"
                      Height="44"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="SelectAreaButton"
                            Grid.Column="0"
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="SelectAreaButton_Click"
                            MouseEnter="SelectAreaButton_MouseEnter"
                            MouseLeave="SelectAreaButton_MouseLeave"
                            PreviewMouseLeftButtonDown="SelectAreaButton_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="SelectAreaButton_PreviewMouseLeftButtonUp"
                            Style="{StaticResource SelectAreaIconButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource ToolbarToolTipStyle}"
                                     Content="Выбрать область" />
                        </Button.ToolTip>
                        <ContentControl ContentTemplate="{StaticResource SelectAreaIconTemplate}" />
                    </Button>

                    <Button x:Name="CopyOriginalButton"
                            Grid.Column="1"
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="CopyOriginalButton_Click"
                            Style="{StaticResource AccentIconButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource ToolbarToolTipStyle}"
                                     Content="Копировать исходный текст" />
                        </Button.ToolTip>
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="18"
                                    Height="18">
                                <Path Data="M3.29381 12.2938C2.45512 12.2938 2.03577 12.2938 1.70498 12.1568C1.26393 11.9741 0.913518 11.6237 0.730827 11.1827C0.593811 10.8518 0.593811 10.4325 0.593811 9.5938V3.4738C0.593811 2.46571 0.593811 1.96165 0.790002 1.57662C0.962568 1.23792 1.23793 0.962555 1.57663 0.789989C1.96167 0.593798 2.46572 0.593798 3.47381 0.593798H9.59381C10.4325 0.593798 10.8518 0.593798 11.1827 0.730814C11.6237 0.913505 11.9741 1.26392 12.1568 1.70496C12.2938 2.03576 12.2938 2.45511 12.2938 3.2938M9.77381 18.5938H15.7138C16.7219 18.5938 17.226 18.5938 17.611 18.3976C17.9497 18.2251 18.2251 17.9497 18.3976 17.611C18.5938 17.226 18.5938 16.7219 18.5938 15.7138V9.7738C18.5938 8.76571 18.5938 8.26162 18.3976 7.8766C18.2251 7.53792 17.9497 7.26255 17.611 7.08999C17.226 6.8938 16.7219 6.8938 15.7138 6.8938H9.77381C8.76572 6.8938 8.26163 6.8938 7.87661 7.08999C7.53793 7.26255 7.26257 7.53792 7.09 7.8766C6.89381 8.26162 6.89381 8.76571 6.89381 9.7738V15.7138C6.89381 16.7219 6.89381 17.226 7.09 17.611C7.26257 17.9497 7.53793 18.2251 7.87661 18.3976C8.26163 18.5938 8.76572 18.5938 9.77381 18.5938Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.1876"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button x:Name="CopyTranslatedButton"
                            Grid.Column="2"
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="CopyTranslatedButton_Click"
                            Style="{StaticResource AccentIconButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource ToolbarToolTipStyle}"
                                     Content="Копировать перевод" />
                        </Button.ToolTip>
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="18"
                                    Height="18">
                                <Path Data="M15.7137 18.5938H8.87357C7.86545 18.5938 7.36135 18.5938 6.97632 18.3976C6.63764 18.2251 6.36224 17.9497 6.1897 17.611C5.9935 17.226 5.9935 16.7219 5.9935 15.7139V8.87404C5.9935 7.86598 5.9935 7.36193 6.1897 6.97691C6.36224 6.63822 6.63764 6.36286 6.97632 6.1903C7.36135 5.99411 7.86545 5.99411 8.87357 5.99411H15.7137C16.7219 5.99411 17.2259 5.99411 17.611 6.1903C17.9497 6.36286 18.225 6.63822 18.3976 6.97691C18.5938 7.36193 18.5938 7.86598 18.5938 8.87404V15.7139C18.5938 16.7219 18.5938 17.226 18.3976 17.611C18.225 17.9497 17.9497 18.2251 17.611 18.3976C17.2259 18.5938 16.7219 18.5938 15.7137 18.5938Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.1876"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <Path Data="M10.9441 0.596318C11.5516 0.604543 11.9163 0.639723 12.2113 0.789984C12.55 0.962545 12.8253 1.2379 12.9979 1.57659C13.1482 1.8715 13.1834 2.23621 13.1916 2.84374M2.84385 0.596318C2.23625 0.604543 1.87156 0.639723 1.57662 0.789984C1.23794 0.962545 0.962535 1.2379 0.79 1.57659C0.639697 1.8715 0.604504 2.2362 0.596314 2.84373M0.596314 10.9435C0.604504 11.551 0.639697 11.9158 0.79 12.2107C0.962535 12.5494 1.23794 12.8248 1.57662 12.9973C1.87156 13.1476 2.23625 13.1828 2.84385 13.191M0.593795 5.99365V7.79361M7.79388 0.593798H5.99393"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.1876"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button x:Name="CloseToolbarButton"
                            Grid.Column="3"
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="CloseToolbarButton_Click"
                            Style="{StaticResource CloseIconButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource ToolbarToolTipStyle}"
                                     Content="Закрыть панель" />
                        </Button.ToolTip>
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="17" Height="17">
                                <Line X1="2.5"
                                      Y1="2.5"
                                      X2="14.5"
                                      Y2="14.5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2.06"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Line X1="14.5"
                                      Y1="2.5"
                                      X2="2.5"
                                      Y2="14.5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2.06"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>

<Window x:Class="RunJargon.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Run Jargon"
        Icon="icon/app.ico"
        Width="1180"
        Height="980"
        MinWidth="1024"
        MinHeight="820"
        Background="#F3F7FB">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="HeroBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E6FFFB" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7E3EF" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="#E2E8F0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FBFDFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource HeroBrush}" CornerRadius="24" Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Width="118"
                                Margin="0,0,0,16"
                                Padding="12,6"
                                Background="#113A4B"
                                CornerRadius="999">
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#8CF5E5"
                                       Text="Windows 11 OCR + Translate" />
                        </Border>
                        <TextBlock FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="Run Jargon" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="16"
                                   Foreground="#D6E5F4"
                                   Text="Горячая клавиша, выделение области, локальный OCR и перевод поверх рабочего процесса. Сейчас каркас уже устойчивый, и следующий шаг — включить боевой перевод без ручной возни с env vars." />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="CaptureAreaButton"
                                Width="220"
                                Margin="0,0,0,12"
                                Click="CaptureAreaButton_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Перевести область" />
                        <Button x:Name="RepeatLastAreaButton"
                                Width="220"
                                Click="RepeatLastAreaButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Повторить прошлую область" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,18,0,18"
                    Padding="20"
                    Background="{StaticResource PanelBrush}"
                    CornerRadius="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,16,0">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#64748B"
                                   Text="Язык исходного текста" />
                        <ComboBox x:Name="SourceLanguageCombo"
                                  Margin="0,8,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Tag="" Content="Автоопределение" />
                            <ComboBoxItem Tag="en" Content="English" />
                            <ComboBoxItem Tag="de" Content="Deutsch" />
                            <ComboBoxItem Tag="ja" Content="Japanese" />
                            <ComboBoxItem Tag="zh-Hans" Content="Chinese Simplified" />
                            <ComboBoxItem Tag="ru" Content="Русский" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#64748B"
                                   Text="Язык перевода" />
                        <ComboBox x:Name="TargetLanguageCombo"
                                  Margin="0,8,0,0"
                                  SelectedIndex="0">
                            <ComboBoxItem Tag="ru" Content="Русский" />
                            <ComboBoxItem Tag="en" Content="English" />
                            <ComboBoxItem Tag="de" Content="Deutsch" />
                            <ComboBoxItem Tag="ja" Content="Japanese" />
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Margin="0,0,16,0"
                            Padding="16"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="#B7F0E8"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#0F766E"
                                       Text="Активный переводчик" />
                            <TextBlock x:Name="ProviderNameText"
                                       Margin="0,8,0,4"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Text="Demo translator" />
                            <TextBlock x:Name="ProviderHintText"
                                       FontSize="12"
                                       Foreground="#0F766E"
                                       TextWrapping="Wrap"
                                       Text="Пока ключи не настроены, приложение работает в безопасном fallback-режиме." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Padding="16"
                            Background="#FFF7ED"
                            BorderBrush="#FED7AA"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#C2410C"
                                       Text="Горячая клавиша" />
                            <TextBlock Margin="0,8,0,4"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Text="Ctrl + Shift + T" />
                            <TextBlock FontSize="12"
                                       Foreground="#9A3412"
                                       TextWrapping="Wrap"
                                       Text="Если комбинация занята другой программой, это сразу будет видно в статусе." />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="20"
                    Background="{StaticResource PanelBrush}"
                    CornerRadius="24">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Text="Настройка Azure Translator" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="#64748B"
                               Text="Если хочешь использовать облако, сохрани ключ здесь. Но теперь приложение умеет и локальный офлайн-перевод без карты и без Azure." />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B"
                                       Text="API key" />
                            <PasswordBox x:Name="AzureApiKeyBox"
                                         Margin="0,8,0,0"
                                         Padding="16,12"
                                         FontSize="14" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B"
                                       Text="Region" />
                            <TextBox x:Name="AzureRegionTextBox"
                                     Margin="0,8,0,0"
                                     Text="global" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,16,0">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B"
                                       Text="Endpoint" />
                            <TextBox x:Name="AzureEndpointTextBox"
                                     Margin="0,8,0,0"
                                     Text="https://api.cognitive.microsofttranslator.com" />
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                    VerticalAlignment="Bottom"
                                    Orientation="Horizontal">
                            <Button x:Name="SaveTranslatorSettingsButton"
                                    Margin="0,0,12,0"
                                    Click="SaveTranslatorSettingsButton_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Сохранить" />
                            <Button x:Name="ClearTranslatorSettingsButton"
                                    Click="ClearTranslatorSettingsButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Очистить" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="20"
                        Background="{StaticResource PanelBrush}"
                        CornerRadius="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Text="Распознанный текст" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="#64748B"
                                       Text="OCR идет локально через Windows OCR. Изображение не уходит в облако." />
                        </StackPanel>

                        <TextBox x:Name="RecognizedTextBox"
                                 Grid.Row="1"
                                 Margin="0,18,0,0"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 Text="Здесь появится текст после выделения области." />
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="20"
                        Background="{StaticResource PanelBrush}"
                        CornerRadius="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="Bold"
                                       Text="Перевод" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="#64748B"
                                       Text="Если настроен Azure Translator, здесь будет реальный перевод. Иначе останется fallback для отладки UX и пайплайна." />
                        </StackPanel>

                        <TextBox x:Name="TranslatedTextBox"
                                 Grid.Row="1"
                                 Margin="0,18,0,0"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 Text="Здесь появится перевод результата OCR." />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Margin="0,18,0,0"
                    Padding="18"
                    Background="{StaticResource PanelBrush}"
                    CornerRadius="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#64748B"
                                   Text="Статус" />
                        <TextBlock x:Name="StatusText"
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Text="Готово к первому захвату." />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#64748B"
                               Text="Env vars: RUN_JARGON_TRANSLATOR_KEY / REGION / ENDPOINT" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>

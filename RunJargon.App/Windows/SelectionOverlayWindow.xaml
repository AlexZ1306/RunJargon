<Window x:Class="RunJargon.App.Windows.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        Background="#26000000"
        Cursor="Cross">
    <Canvas x:Name="RootCanvas"
            Background="Transparent"
            Focusable="True"
            MouseLeftButtonDown="RootCanvas_MouseLeftButtonDown"
            MouseMove="RootCanvas_MouseMove"
            MouseLeftButtonUp="RootCanvas_MouseLeftButtonUp"
            KeyDown="RootCanvas_KeyDown">
        <Border x:Name="SelectionBorder"
                IsHitTestVisible="False"
                Visibility="Collapsed"
                BorderBrush="#5EEAD4"
                BorderThickness="2"
                Background="#22CCFBF1"
                CornerRadius="12" />

        <Border x:Name="HintPanel"
                IsHitTestVisible="False"
                Padding="14,10"
                Background="#0F172A"
                CornerRadius="16">
            <StackPanel>
                <TextBlock FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="Выдели область для OCR и перевода" />
                <TextBlock x:Name="HintSubText"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#BFDBFE"
                           Text="Esc отмена" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>

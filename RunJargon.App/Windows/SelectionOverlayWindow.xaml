<Window x:Class="RunJargon.App.Windows.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RunJargon.App.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        Background="Transparent"
        Cursor="Cross">
    <Canvas x:Name="RootCanvas"
            Background="Transparent"
            Focusable="True"
            MouseLeftButtonDown="RootCanvas_MouseLeftButtonDown"
            MouseMove="RootCanvas_MouseMove"
            MouseLeftButtonUp="RootCanvas_MouseLeftButtonUp"
            KeyDown="RootCanvas_KeyDown">
        <Rectangle x:Name="DimOverlay"
                   Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                   Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                   IsHitTestVisible="False"
                   Fill="#26000000" />

        <Border x:Name="SelectionBorder"
                IsHitTestVisible="False"
                Visibility="Collapsed"
                BorderBrush="#5EEAD4"
                BorderThickness="2"
                Background="#22CCFBF1"
                CornerRadius="12"
                Panel.ZIndex="5" />

        <controls:CaptureSelectionToolbar x:Name="CaptureToolbar"
                                          Panel.ZIndex="10" />
    </Canvas>
</Window>
